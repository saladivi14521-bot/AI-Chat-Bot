# ============================================
# SmartRep AI - Backend Environment Variables
# ============================================

# App
APP_NAME=SmartRep AI
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql+asyncpg://smartrep:smartrep_pass@localhost:5432/smartrep_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_PREFIX=smartrep_

# Facebook Messenger
FB_APP_ID=your-facebook-app-id
FB_APP_SECRET=your-facebook-app-secret
FB_VERIFY_TOKEN=smartrep-webhook-verify-token
FB_GRAPH_API_URL=https://graph.facebook.com/v21.0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# File Storage (S3/R2 - for later)
# S3_BUCKET=smartrep-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Admin
ADMIN_EMAIL=admin@smartrep.ai
ADMIN_PASSWORD=admin123456

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
